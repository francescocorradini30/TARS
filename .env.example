# Copy this file to `.env` and fill in your own values.
#   cp .env.example .env        (macOS/Linux)
#   copy .env.example .env      (Windows cmd)
# `.env` is gitignored — your real keys never get committed.

# ── LLM brain: failover chain ────────────────────────────────────────────────
# TARS tries these providers in order and falls through on rate-limit/outage, so no
# single free tier capping out can take him down. His personality + memory are the
# same on every one — only the reasoning model changes underneath. A cloud provider
# is only in the chain if you give it a key; "ollama" is the local offline floor.
#   - groq      : llama-3.3-70b, free tier, ~1k req/day. https://console.groq.com/keys
#   - cerebras  : same llama-3.3-70b but FASTER, 1M tokens/day free (8k context cap).
#                 https://cloud.cerebras.ai
#   - gemini    : Gemini Flash, strong + huge context, generous free tier.
#                 https://aistudio.google.com/apikey
#   - ollama    : local model on your GPU — keeps TARS alive fully offline (weaker).
LLM_CHAIN=groq,cerebras,gemini,ollama

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama (local). Pull the model first:  ollama pull llama3.2:3b
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434

# Circuit-breaker tuning (seconds). A 429 with a Retry-After header is honored exactly;
# these are the fallbacks. FALLBACK = transient skip (rate limit w/o header, network,
# 5xx); FATAL = bad key / malformed request, parked long. REPROBE_IDLE = silence before
# we re-check a recovered provider so the next turn already uses the best brain.
LLM_FALLBACK_COOLDOWN=30
LLM_FATAL_COOLDOWN=3600
LLM_REPROBE_IDLE_SECONDS=10

# ── Speech-to-text (faster-whisper) ──────────────────────────────────────────
# tiny / base / small / medium / large-v3 / large-v3-turbo
# large-v3-turbo: near large-v3 accuracy, ~1.6GB, medium-like latency. Drop to
# "small" if latency hurts, or if the LLM also runs locally and VRAM is tight.
WHISPER_MODEL=large-v3-turbo
WHISPER_DEVICE=cuda            # "cuda" (NVIDIA GPU) or "cpu"

# Input microphone. "auto" (default) auto-picks by STT_DEVICE_PRIORITY below; empty
# = system default; otherwise a device index or a name substring. List devices:
#   python -c "import sounddevice as sd; print(sd.query_devices())"
# Prefer a clean device: a laptop's built-in mic array can sit at a noise floor
# ABOVE the VAD threshold, which keeps the listener permanently "on".
STT_INPUT_DEVICE=auto
# Preference order for "auto": case-insensitive name substrings, best first. First
# connected match wins; if none, the system default (laptop mic) is used.
STT_DEVICE_PRIORITY=redmi buds 6, focusrite

# RMS energy above which a 32ms chunk counts as speech. Raise it on a noisy mic
# (the startup noise-floor log tells you where silence sits).
STT_ENERGY_THRESHOLD=0.012

# Silence (ms) that ends an utterance. This is your mid-sentence pause tolerance:
# lower = snappier replies but cuts you off on natural pauses; higher = fewer cutoffs
# but TARS waits a bit longer before answering. ~1200 rides out most pauses.
STT_SILENCE_MS=1200
# Hard cap (s) on one utterance with no silence — safety net + max monologue length.
# Raise if you tell long stories without pausing and get cut at the cap.
STT_MAX_UTTERANCE_S=20

# ── Persona ──────────────────────────────────────────────────────────────────
USER_NAME=Cooper              # how TARS addresses you
KOKORO_VOICE=am_michael       # Kokoro TTS voice (see kokoro-onnx voice list)

# ── Persistent memory (optional) ─────────────────────────────────────────────
# Which model distills a finished session into long-term memory. "groq" gives far
# better synthesis (sends that session's transcript to Groq); "ollama" stays local.
CONSOLIDATION_BACKEND=ollama
