# Copy this file to `.env` and fill in your own values.
#   cp .env.example .env        (macOS/Linux)
#   copy .env.example .env      (Windows cmd)
# `.env` is gitignored — your real keys never get committed.

# ── LLM backend ──────────────────────────────────────────────────────────────
# "ollama" = fully local model on your GPU (free, offline, private; shares VRAM
#            with Whisper). "groq" = cloud inference (free tier) that frees ~2.8GB
#            of VRAM and runs a much bigger model, at the cost of sending the
#            conversation text off-machine and needing an API key + internet.
LLM_BACKEND=ollama

# Only needed when LLM_BACKEND=groq. Get a free key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (local). Pull the model first:  ollama pull llama3.2:3b
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434

# ── Speech-to-text (faster-whisper) ──────────────────────────────────────────
# tiny / base / small / medium / large-v3 / large-v3-turbo
# large-v3-turbo: near large-v3 accuracy, ~1.6GB, medium-like latency. Drop to
# "small" if latency hurts, or if the LLM also runs locally and VRAM is tight.
WHISPER_MODEL=large-v3-turbo
WHISPER_DEVICE=cuda            # "cuda" (NVIDIA GPU) or "cpu"

# Input microphone. Empty = system default. Otherwise a device index or a name
# substring. List devices:  python -c "import sounddevice as sd; print(sd.query_devices())"
# Prefer a clean external interface: a laptop's built-in mic array can sit at a
# noise floor ABOVE the VAD threshold, which keeps the listener permanently "on".
STT_INPUT_DEVICE=

# RMS energy above which a 32ms chunk counts as speech. Raise it on a noisy mic
# (the startup noise-floor log tells you where silence sits).
STT_ENERGY_THRESHOLD=0.012

# ── Persona ──────────────────────────────────────────────────────────────────
USER_NAME=Cooper              # how TARS addresses you
KOKORO_VOICE=am_michael       # Kokoro TTS voice (see kokoro-onnx voice list)

# ── Persistent memory (optional) ─────────────────────────────────────────────
# Which model distills a finished session into long-term memory. "groq" gives far
# better synthesis (sends that session's transcript to Groq); "ollama" stays local.
CONSOLIDATION_BACKEND=ollama
